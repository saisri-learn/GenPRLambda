# GitHub Configuration
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repository-name
DEFAULT_BASE_BRANCH=main

# LLM Configuration
LLM_PROVIDER=anthropic  # Options: anthropic, openai
LLM_MODEL=claude-3-5-sonnet-20241022  # For Anthropic: claude-3-5-sonnet-20241022, For OpenAI: gpt-4, gpt-4-turbo
LLM_API_KEY=your_llm_api_key_here
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4000

# Lambda Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
TIMEOUT_BUFFER=30  # Seconds before Lambda timeout to gracefully stop

# AWS Configuration (for local testing with CDK)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
